generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id             String        @id
  name           String?
  joinedAt       DateTime      @default(now())
  config         GuildConfig?
  currencies     Currency[]
  economyUsers   EconomyUser[]
  coinflipStats  CoinflipStats[]
  birthdays      Birthday[]
}

model GuildConfig {
  guildId            String  @id
  guild              Guild   @relation(fields: [guildId], references: [id])
  prefix             String  @default("/")
  welcomeChannelId   String?
  logChannelId       String?
  logEnabled         Boolean @default(false)
  modules            String  @default("fun,utility")
  birthdayEnabled    Boolean @default(false)
  birthdayChannelId  String?
  birthdayMessage    String  @default("Feliz aniversario, {user}!")
  gamesEnabled       Boolean @default(true)
}

model ActivityLog {
  id        String   @id @default(uuid())
  guildId   String
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Currency {
  id            String         @id @default(uuid())
  guildId       String
  guild         Guild          @relation(fields: [guildId], references: [id])
  name          String
  symbol        String         @default("$")
  taxRate       Float          @default(0)
  exchangeRate  Float          @default(1.0)
  economyUsers  EconomyUser[]

  @@unique([guildId, name])
}

model EconomyUser {
  id         String   @id @default(uuid())
  guildId    String
  guild      Guild    @relation(fields: [guildId], references: [id])
  userId     String
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])
  balance    Int      @default(0)
  bank       Int      @default(0)

  @@unique([guildId, userId, currencyId])
}

model CoinflipStats {
  id      String @id @default(uuid())
  guildId String
  userId  String
  wins    Int    @default(0)
  total   Int    @default(0)
  guild   Guild  @relation(fields: [guildId], references: [id])

  @@unique([guildId, userId])
}

model Birthday {
  id        String   @id @default(uuid())
  guildId   String
  userId    String
  day       Int
  month     Int
  createdAt DateTime @default(now())
  guild     Guild    @relation(fields: [guildId], references: [id])

  @@unique([guildId, userId])
}