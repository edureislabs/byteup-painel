generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id           String        @id
  name         String?
  joinedAt     DateTime      @default(now())
  config       GuildConfig?
  economyUsers EconomyUser[]
}

model GuildConfig {
  guildId          String  @id
  guild            Guild   @relation(fields: [guildId], references: [id])
  prefix           String  @default("/")
  welcomeChannelId String?
  logChannelId     String?
  logEnabled       Boolean @default(false)
  modules          String  @default("fun,utility")
}

model ActivityLog {
  id        String   @id @default(uuid())
  guildId   String
  userId    String?
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model EconomyUser {
  id      String @id @default(uuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id])
  userId  String
  balance Int    @default(0)
  bank    Int    @default(0)

  @@unique([guildId, userId])
}